# Neon — in https://console.neon.tech open your project → Connection details → copy the URI.
# Prefer the pooled / serverless string for Next.js runtime on Netlify and `@neondatabase/serverless`
# (often includes `-pooler` in the host).
DATABASE_URL=

# Prefer the direct (non-pooled) string for migrations / Drizzle Kit.
# Neon often labels this as "Direct connection" (host typically does NOT include `-pooler`).
DATABASE_URL_DIRECT=

# Better Auth — use `pnpm exec auth secret` or `openssl rand -base64 32`
BETTER_AUTH_SECRET=

# Better Auth Dash / infra — API key from https://dash.better-auth.com (after onboarding)
BETTER_AUTH_API_KEY=

# Server + cookie base URL (no trailing slash). Must match the URL you open in the browser
# when using ngrok, Netlify, or previews (both this and NEXT_PUBLIC_APP_URL should use that host).
BETTER_AUTH_URL=http://localhost:3000

# In the browser bundle; should match BETTER_AUTH_URL for the same deployment.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: comma-separated extra allowed origins (e.g. alternate preview URLs).
# BETTER_AUTH_TRUSTED_ORIGINS=https://branch--site.netlify.app,https://xxxx.ngrok-free.app

# Optional (dev only): extra hostnames for Next.js allowedDevOrigins if the tunnel host
# is not already derivable from BETTER_AUTH_URL / NEXT_PUBLIC_APP_URL (e.g. a second ngrok URL).
# ALLOWED_DEV_ORIGINS=other-subdomain.ngrok-free.app

# -----------------------------
# Social login (clients only)
# Redirect URIs (local):
# - http://localhost:3000/api/auth/callback/google
# - http://localhost:3000/api/auth/callback/facebook
# Redirect URIs (prod):
# - https://your-domain.com/api/auth/callback/google
# - https://your-domain.com/api/auth/callback/facebook
# -----------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Optional: when multiple `affiliate_site` rows exist, pin which site is used for public catalog pricing.
# Optional demo catalog (`pnpm db:seed:demo`) inserts affiliate site `seed-affiliate-demo-1`.
# PRICING_AFFILIATE_SITE_ID=seed-affiliate-demo-1

# Vitest integration (RLS): set RUN_DB_TESTS=1 and use a disposable Postgres with migrations applied.
# RUN_DB_TESTS=

# Guest link after payment — HMAC cookie `vt_link_intent`. Required for prepare + link; without it those routes return 503.
# Must be ≥ 32 bytes as UTF-8 (character count can be lower for multi-byte chars). Do not reuse Paddle secrets.
# Generate: openssl rand -base64 32
GUEST_LINK_INTENT_SECRET=

# Guest link feature kill switch: only the string `false` disables prepare + link (503).
# Unset or any other value = enabled (including staging). Do not assume “unset = off”.
# GUEST_LINK_AFTER_AUTH_ENABLED=true

# Portal workspace highlight for `?applicationId=` deep links (`false` → slip to /apply/...?linked=1).
# WORKSPACE_APPLICATION_HIGHLIGHT_ENABLED=true

# Optional: run tests/integration/guest-link-audit-rls.test.ts against a real DATABASE_URL.
# GUEST_LINK_RLS_INTEGRATION=

# Internal cron / cleanup: POST /api/internal/cleanup-drafts with header x-internal-secret
# INTERNAL_CRON_SECRET=

# -----------------------------
# Passport OCR (Gemini)
# -----------------------------
# API key from https://aistudio.google.com/ — required at runtime for POST /extract.
# CI must run without this (tests mock the SDK).
# GEMINI_API_KEY=
# Override the default OCR model if needed.
# GEMINI_MODEL_ID=gemini-2.5-flash
# Optional: bump to invalidate cached prompts / extraction rows.
# GEMINI_PROMPT_VERSION=1


# Payments: `paddle` (default) or `ziina` — single active provider per deployment.
# PAYMENT_PROVIDER=paddle

# Local dev safety: payments require an https origin (tunnel) so webhooks can reach your machine.
# Set NEXT_PUBLIC_APP_URL / BETTER_AUTH_URL to your ngrok https URL, or (not recommended) bypass:
# PAYMENTS_ALLOW_INSECURE_LOCALHOST=true

# Paddle API
PADDLE_API_KEY=pdl_sdbx_apikey
PADDLE_WEBHOOK_SECRET=pdl_ntfset_...

# Paddle Frontend
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=test_...
NEXT_PUBLIC_PADDLE_ENVIRONMENT=sandbox

# Ziina (when PAYMENT_PROVIDER=ziina) — server-only; webhook at POST /api/webhooks/ziina
# ZIINA_API_BASE_URL=https://api-v2.ziina.com/api
# ZIINA_ACCESS_TOKEN=
# ZIINA_WEBHOOK_SECRET=
# ZIINA_TEST_MODE=true
# ZIINA_ENFORCE_WEBHOOK_IP_ALLOWLIST=false
# Dev only — never in production: ZIINA_WEBHOOK_ALLOW_UNSIGNED=true

